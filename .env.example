# =============================================================================
# AIGateway Interceptor - Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# NEVER commit .env to version control.
# =============================================================================

# --- Security ---
# Secret key for JWT token signing. Generate a strong random value:
#   openssl rand -hex 32
SECRET_KEY=change-this-to-a-random-secret-key

# --- Database ---
# PostgreSQL connection string
DATABASE_URL=postgresql://aigateway:secret@postgres:5432/aigateway
POSTGRES_USER=aigateway
POSTGRES_PASSWORD=secret
POSTGRES_DB=aigateway

# --- Cache / Message Broker ---
# Redis connection string
REDIS_URL=redis://redis:6379

# --- DLP (Data Loss Prevention) ---
# Mode for handling sensitive data findings:
#   anonymize - Replace sensitive data with masked values
#   block     - Block the entire request
#   log_only  - Log findings but allow the request through
DLP_MODE=anonymize

# --- Logging ---
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Number of days to retain audit logs before cleanup
LOG_RETENTION_DAYS=90

# --- CORS ---
# Comma-separated list of allowed origins for the API
CORS_ORIGINS=http://localhost:3000,http://localhost

# --- Dashboard ---
# API URL as seen by the browser (for the React dashboard)
VITE_API_URL=http://localhost:8000

# --- Proxy ---
# Port for the mitmproxy listener
PROXY_PORT=8080

# Comma-separated list of AI provider domains to intercept
AI_PROVIDER_DOMAINS=api.openai.com,api.anthropic.com,generativelanguage.googleapis.com,api.cohere.ai,api.mistral.ai

# --- TLS ---
# Path to CA certificate and key (inside the container)
CA_CERT_PATH=/certs/aigateway-ca.crt
CA_KEY_PATH=/certs/aigateway-ca.key
